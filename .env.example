# gdrag v2 - Environment Configuration
# Copy this file to .env and fill in your values

# ─── API Configuration ──────────────────────────────────────────────────────
GDRAG_DEBUG=false
GDRAG_API_HOST=0.0.0.0
GDRAG_API_PORT=8000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gdrag
POSTGRES_USER=gdrag
POSTGRES_PASSWORD=your_password_here

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Memgraph ────────────────────────────────────────────────────────────────
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=admin
MEMGRAPH_PASSWORD=memgraph2024

# ─── OpenAI (optional, for OpenAI embeddings) ───────────────────────────────
# OPENAI_API_KEY=sk-your-key-here

# ─── Embedding Configuration ────────────────────────────────────────────────
# Options: local, openai, both
EMBEDDING_PROVIDER=local

# ─── JWT Secret (for API authentication) ────────────────────────────────────
JWT_SECRET=change-me-in-production-use-random-string